{
  "name": "i3dad",
  "version": "1.0.0",
  "type": "module",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "node scripts/expo-offline.cjs start --web",
    "web:clear": "node scripts/expo-offline.cjs start --web --clear",
    "email:server": "node server/emailServer.cjs",
    "email:test": "node server/sendTestEmail.cjs",
    "generate-questions": "node scripts/questionGenerator.js",
    "import-questions": "node scripts/importQuestionsCsv.js",
    "seed-subjects": "node scripts/seedSubjects.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.19",
    "@supabase/supabase-js": "^2.89.0",
    "@types/react": "~19.1.10",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "expo": "^54.0.33",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.6.2",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.2.0",
    "pdf-parse": "^2.4.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.2.4",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "typescript": "^5.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "jest": "29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native|react-native|@react-navigation|expo(nent)?|expo-.*|@expo(nent)?/.*|react-native-svg)/)"
    ]
  },
  "private": true
}
