# Public client env (embedded in web/mobile builds). Never put service-role keys here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional: deployed email API (required in production for principal invite / password reset email flows)
# Do NOT use localhost in production builds.
EXPO_PUBLIC_EMAIL_API_URL=https://your-email-api.example.com

# Server-only scripts / local admin utilities. Never expose in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Edge Function secrets (set in Supabase dashboard, not in Expo app)
PROJECT_URL=https://your-project-ref.supabase.co
PROJECT_ANON_KEY=your-public-anon-key
PROJECT_SERVICE_ROLE_KEY=your-service-role-key
INVITE_REDIRECT_URL=https://your-production-domain/principal-register

# Local-only email server (dev)
EMAIL_HOST_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=
